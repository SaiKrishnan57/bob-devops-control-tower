# IBM watsonx.ai Configuration
# Copy this file to .env and fill in your credentials

# watsonx.ai API Key (required)
WATSONX_API_KEY=ApiKey-64fac056-aa25-42a8-a655-4acb3e347330

# watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=1180b726-6a0b-42e5-a91d-1d77ffa8ba2c

# watsonx.ai URL (optional, defaults to US South region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model Configuration
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
WATSONX_MAX_TOKENS=500
WATSONX_TEMPERATURE=0.7